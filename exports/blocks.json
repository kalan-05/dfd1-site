41\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0439 \u043a\u043b\u0438\u043d\u0438\u043a\u0443:","history_text":"\u0412 1998-2002 \u0433\u043e\u0434\u0430\u0445 \u0431\u044b\u043b\u0438 \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u044b \u043f\u0435\u0440\u0432\u044b\u0435 \u0430\u043f\u043f\u0430\u0440\u0430\u0442\u044b \u0434\u043b\u044f \u0441\u0443\u0442\u043e\u0447\u043d\u043e\u0433\u043e \u043c\u043e\u043d\u0438\u0442\u043e\u0440\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u042d\u041a\u0413 \u0438 \u0432\u0435\u043b\u043e\u044d\u0440\u0433\u043e\u043c\u0435\u0442\u0440\u0438\u0438.\n\u0412 2000 \u0433\u043e\u0434\u0443 \u0432\u043d\u0435\u0434\u0440\u0435\u043d \u043a\u0430\u0440\u0434\u0438\u043e\u043f\u0443\u043b\u044c\u043c\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0439 \u043d\u0430\u0433\u0440\u0443\u0437\u043e\u0447\u043d\u044b\u0439 \u0442\u0435\u0441\u0442 Sensor Medics (\u0421\u0428\u0410, V-max-29).\n\u0412 2012 \u0433\u043e\u0434\u0443 - \u0441\u0442\u0440\u0435\u0441\u0441-\u0441\u0438\u0441\u0442\u0435\u043c\u0430 Cardiosoft (GE, \u0421\u0428\u0410) \u0438 \u0433\u043e\u0440\u0438\u0437\u043e\u043d\u0442\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u0435\u043b\u043e\u044d\u0440\u0433\u043e\u043c\u0435\u0442\u0440 \u0434\u043b\u044f \u0441\u0442\u0440\u0435\u0441\u0441-\u044d\u0445\u043e\u043a\u0430\u0440\u0434\u0438\u043e\u0433\u0440\u0430\u0444\u0438\u0438.\n\u0412 2018 \u0433\u043e\u0434\u0443 \u0431\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u044d\u0445\u043e\u043a\u0430\u0440\u0434\u0438\u043e\u0433\u0440\u0430\u0444\u0443 Vivid E90 \u0441\u0442\u0430\u043b\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u0447\u0440\u0435\u0437\u043f\u0438\u0449\u0435\u0432\u043e\u0434\u043d\u043e\u0439 \u042d\u0425\u041e\u041a\u0413.\n\u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u043d\u043e\u043c\u0443 \u043f\u043e\u0434\u0445\u043e\u0434\u0443 \u043a \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0435 \u0441\u0435\u0440\u0434\u0435\u0447\u043d\u043e-\u0441\u043e\u0441\u0443\u0434\u0438\u0441\u0442\u044b\u0445 \u0437\u0430\u0431\u043e\u043b\u0435\u0432\u0430\u043d\u0438\u0439 \u043c\u044b \u043f\u043e\u043c\u043e\u0433\u0430\u0435\u043c \u0432\u0440\u0430\u0447\u0430\u043c \u043f\u043e\u0434\u0431\u0438\u0440\u0430\u0442\u044c \u043e\u043f\u0442\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0435 \u043b\u0435\u0447\u0435\u043d\u0438\u0435 \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0442\u044c \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u043f\u0440\u043e\u0444\u0438\u043b\u0430\u043a\u0442\u0438\u043a\u0438.","block3_diagnosis":"\u0418\u0411\u0421, \u0430\u0440\u0438\u0442\u043c\u0438\u0439, \u0441\u0435\u0440\u0434\u0435\u0447\u043d\u043e\u0439 \u043d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e\u0441\u0442\u0438, \u0430\u0440\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u043e\u0439 \u0433\u0438\u043f\u0435\u0440\u0442\u0435\u043d\u0437\u0438\u0438.","block1_history_text":"\u0412 \u0444\u0435\u0432\u0440\u0430\u043b\u0435 1982 \u0433\u043e\u0434\u0430 \u043a\u0430\u0431\u0438\u043d\u0435\u0442 \u0431\u044b\u043b \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d \u0432 \u043e\u0442\u0434\u0435\u043b\u0435\u043d\u0438\u0435. \u0412 1983 \u0433\u043e\u0434\u0443 \u0432 \u043a\u043b\u0438\u043d\u0438\u043a\u0435 \u0444\u0430\u043a\u0443\u043b\u044c\u0442\u0435\u0442\u0441\u043a\u043e\u0439 \u0442\u0435\u0440\u0430\u043f\u0438\u0438 \u043f\u0440\u0438 \u0441\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0438 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u043e\u0440\u0430 \u0412\u043b\u0430\u0434\u0438\u043c\u0438\u0440\u0430 \u0410\u043d\u0434\u0440\u0435\u0435\u0432\u0438\u0447\u0430 \u0410\u043b\u043c\u0430\u0437\u043e\u